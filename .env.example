# === Telegram Config ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === Vinted Search Config ===
# URL di ricerca Vinted (copia dal browser)
VINTED_SEARCH_URL=https://www.vinted.it/catalog?search_text=Apple%20Watch%2011&search_id=34335776811&order=newest_first&page=1&time=1779910665&price_from=80&currency=EUR

# === Vercel Cron Monitor Config ===
# Quanti annunci leggere ad ogni run cron
MAX_ITEMS_PER_RUN=20

# Protegge gli endpoint /api/cron e /api/run-now
CRON_SECRET=replace_with_random_secret

# Upstash Redis REST credentials (stato persistente annunci visti)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
